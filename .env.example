# ===========================================
# Multi-Agent Data Analyzer - Environment
# ===========================================

# OpenAI API Key (required for backend / Railway)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=paste-your-openai-api-key-here

# Backend server port (optional, default: 8001)
PORT=8001

# ---- Vercel Frontend Environment Variable ----
# Set this in Vercel project settings → Environment Variables
# pointing to your Railway backend URL (e.g. https://your-app.up.railway.app)
# NEXT_PUBLIC_API_URL=https://your-railway-backend-url.up.railway.app
